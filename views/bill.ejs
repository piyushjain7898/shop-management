<!DOCTYPE html>
<html>

<head>
    <title>Generate Bill</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background: url('/images/dashboard-bg.jpg') no-repeat center center/cover;
        }

        body::before {
            content: "";
            position: fixed;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.65);
            z-index: -1;
        }

        .sidebar {
            position: fixed;
            width: 250px;
            height: 100%;
            background: rgba(17, 24, 39, 0.95);
            padding-top: 30px;
        }

        .sidebar a {
            color: #cbd5e1;
            display: block;
            padding: 12px 20px;
            margin: 5px 10px;
            border-radius: 6px;
            text-decoration: none;
        }

        .sidebar a:hover {
            background: #374151;
            color: white;
        }

        .main-content {
            margin-left: 250px;
            padding: 40px;
        }

        .glass-box {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 40px;
            color: white;
            max-width: 500px;
        }

        .form-control {
            background: rgba(255, 255, 255, 0.9);
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <h4 class="text-center text-white mb-4">Garments Admin</h4>
        <a href="/dashboard">Dashboard</a>
        <a href="/products">Products</a>
        <a href="/bill">Billing</a>
        <a href="/logout">Logout</a>
    </div>

    <div class="main-content d-flex justify-content-center">
        <div class="glass-box">

            <h4 class="mb-4">Generate Bill</h4>

            <form id="billForm" method="POST">

                <div class="mb-3">
                    <label>Select Product</label>
                    <select name="product_id" class="form-control" required>
                        <% products.forEach(p=> { %>
                            <option value="<%= p.id %>">
                                <%= p.name %> - ₹ <%= p.price %>
                            </option>
                            <% }) %>
                    </select>
                </div>

                <div class="mb-3">
                    <label>Quantity</label>
                    <input type="number" name="quantity" class="form-control" required>
                </div>

                <button class="btn btn-success w-100">
                    <i class="bi bi-file-earmark-pdf"></i> Generate Invoice
                </button>
            </form>

        </div>
    </div>
    <script>
        document.getElementById("billForm").addEventListener("submit", function (e) {
            e.preventDefault();

            const formData = new FormData(this);

            fetch('/bill', {
                method: 'POST',
                body: new URLSearchParams(formData)
            })
                .then(res => res.json())
                .then(data => {

                    // Open PDF in new tab
                    window.open("/" + data.file, "_blank");

                    // Redirect to dashboard after short delay
                    setTimeout(() => {
                        window.location.href = "/dashboard";
                    }, 800);

                })
                .catch(err => {
                    alert("Error generating invoice");
                    console.log(err);
                });
        });
    </script>


</body>

</html>