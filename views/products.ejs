<!DOCTYPE html>
<html>
<head>
    <title>Products</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background: url('/images/dashboard-bg.jpg') no-repeat center center/cover;
        }

        body::before {
            content: "";
            position: fixed;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.65);
            z-index: -1;
        }

        .sidebar {
            position: fixed;
            width: 250px;
            height: 100%;
            background: rgba(17,24,39,0.95);
            padding-top: 30px;
        }

        .sidebar a {
            color: #cbd5e1;
            display: block;
            padding: 12px 20px;
            margin: 5px 10px;
            border-radius: 6px;
            text-decoration: none;
        }

        .sidebar a:hover {
            background: #374151;
            color: white;
        }

        .main-content {
            margin-left: 250px;
            padding: 40px;
        }

        .glass-box {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 30px;
            color: white;
        }

        table {
            background: white;
            border-radius: 12px;
            overflow: hidden;
        }
    </style>
</head>

<body>

<div class="sidebar">
    <h4 class="text-center text-white mb-4">Garments Admin</h4>
    <a href="/dashboard">Dashboard</a>
    <a href="/products">Products</a>
    <a href="/bill">Billing</a>
    <a href="/logout">Logout</a>
</div>

<div class="main-content">
    <div class="glass-box">

        <div class="d-flex justify-content-between mb-4">
            <h4>Product Management</h4>
            <a href="/add-product" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i> Add Product
            </a>
        </div>

        <table class="table table-bordered table-hover shadow">
            <thead class="table-dark text-center">
                <tr>
                    <th>ID</th>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Size</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
            <% products.forEach(p => { %>
                <tr class="text-center align-middle">
                    <td><%= p.id %></td>
                    <td>
                        <% if(p.image) { %>
                            <img src="/images/<%= p.image %>" width="60" height="60" style="object-fit:cover; border-radius:8px;">
                        <% } else { %>
                            No Image
                        <% } %>
                    </td>
                    <td><%= p.name %></td>
                    <td><%= p.category %></td>
                    <td><%= p.size %></td>
                    <td>₹ <%= p.price %></td>
                    <td><%= p.quantity %></td>
                    <td>
                        <a href="/edit-product/<%= p.id %>" class="btn btn-warning btn-sm">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="/delete-product/<%= p.id %>" class="btn btn-danger btn-sm"
                           onclick="return confirm('Delete this product?')">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            <% }) %>
            </tbody>
        </table>

    </div>
</div>

</body>
</html>
